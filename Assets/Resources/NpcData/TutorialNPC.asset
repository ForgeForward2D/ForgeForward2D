  m_Script: {fileID: 11500000, guid: c171048670bebf84fb4c45b4fec3d39f, type: 3}
  m_Name: TutorialNPC
  m_EditorClassIdentifier: Assembly-CSharp::NpcType
  displayName: Tutorial
  characterSprite: {fileID: -1406016075, guid: 56b28c1a417c54300b97e1bcb8daad3f, type: 3}
  dialogueLines:
  - Welcome to ForgeForward2D! I will give you a quick overview about the controls.
    Press S to continue.
  - You can open this help menu at any point by pressing Z.
  - Press W / A / S / D or Arrow Keys to move around the world.
  - Press J or Left Click to break blocks. Press K or Right Click to interact with
    NPCs and objects in the world.
  - Press Arrow Down / S / Right Click to advance in dialogues. Press Arrow Up /
    W / Left Click to go back.
  - Use mouse scroll or number keys 1-3 to select tools in your Hotbar.
  - Press E to open your Inventory. Press U to view your Achievements. Press Escape
    to close any open menu.
  - Good luck, adventurer!
